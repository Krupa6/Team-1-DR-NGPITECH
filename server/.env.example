# AI Future Campus - Environment Variables

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ai-campus?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# OpenRouter API Configuration
# Get your key from: https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here
# Models available: claude-3-opus, gpt-4-turbo, gpt-3.5-turbo, mistral-7b, etc.
AI_MODEL=claude-3-opus

# Server Configuration
PORT=5000
NODE_ENV=development

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000
